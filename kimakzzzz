#!/bin/bash

NC='\033[0m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'

if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}Harus root!${NC}"
   exit 1
fi

NEW_SSH_PORT="${1:-8822}"
USERNAME="rendzz"

echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}AUTO SECURE VPS - SAFE PTERODACTYL MODE${NC}"
echo -e "${GREEN}============================================${NC}"

# Detect port yang sedang dipakai
echo -e "${YELLOW}Detecting active ports...${NC}"

ACTIVE_PORTS=$(ss -tulpn | grep LISTEN | awk '{print $5}' | cut -d: -f2 | sort -n | uniq)

echo -e "${GREEN}Port aktif:${NC}"
echo "$ACTIVE_PORTS"

# Buat user jika belum ada
if ! id "$USERNAME" &>/dev/null; then

PASS=$(openssl rand -base64 12)

useradd -m -s /bin/bash $USERNAME
echo "$USERNAME:$PASS" | chpasswd
usermod -aG sudo $USERNAME

echo -e "${GREEN}User dibuat:${NC} $USERNAME"
echo -e "${GREEN}Password:${NC} $PASS"

fi

# Backup ssh config
cp /etc/ssh/sshd_config /etc/ssh/sshd_config.backup

# Set port SSH baru TANPA hapus config lain
grep -q "^Port $NEW_SSH_PORT" /etc/ssh/sshd_config || echo "Port $NEW_SSH_PORT" >> /etc/ssh/sshd_config

# Hardening aman
sed -i 's/^#PermitRootLogin yes/PermitRootLogin no/' /etc/ssh/sshd_config
sed -i 's/^PermitRootLogin yes/PermitRootLogin no/' /etc/ssh/sshd_config

# Install fail2ban jika belum
if ! command -v fail2ban-server &>/dev/null; then
apt update -y
apt install fail2ban -y
fi

cat > /etc/fail2ban/jail.local <<EOF
[sshd]
enabled = true
port = $NEW_SSH_PORT
maxretry = 3
bantime = 3600
EOF

systemctl restart fail2ban
systemctl enable fail2ban

# Firewall SAFE MODE (tidak reset)
if command -v ufw &>/dev/null; then

echo -e "${YELLOW}Menambahkan port aktif ke firewall...${NC}"

for PORT in $ACTIVE_PORTS; do
ufw allow $PORT/tcp >/dev/null 2>&1
done

ufw allow $NEW_SSH_PORT/tcp >/dev/null 2>&1

ufw status | grep inactive && ufw --force enable

fi

# Restart ssh safely
systemctl restart sshd || systemctl restart ssh

echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}✓ VPS SECURED - PANEL AMAN${NC}"
echo -e "${GREEN}============================================${NC}"

echo -e "SSH Port : $NEW_SSH_PORT"
echo -e "User     : $USERNAME"

echo ""
echo -e "${GREEN}Panel ports tetap terbuka otomatis${NC}"
echo -e "${GREEN}Tidak ada port panel yang diubah${NC}"

echo ""
echo -e "Login:"
echo -e "ssh -p $NEW_SSH_PORT $USERNAME@IP-VPS"
