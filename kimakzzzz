#!/bin/bash

# Auto Security VPS Installer
# KHUSUS UNTUK VPS PTERODACTYL
# Hanya konfigurasi SSH & firewall, TIDAK ganggu panel

# Warna output
NC='\033[0m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'

# Cek root
if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}Harus root!${NC}"
   exit 1
fi

# Set variable
NEW_SSH_PORT="${1:-8822}"  # Port SSH baru (default 8822)
USERNAME="rendzz"

echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}   AUTO SECURE VPS - PTERODACTYL EDITION${NC}"
echo -e "${GREEN}============================================${NC}"
echo -e "Port SSH Baru : ${YELLOW}$NEW_SSH_PORT${NC}"
echo -e "Username      : ${YELLOW}$USERNAME${NC}"
echo -e "Panel Status  : ${GREEN}TIDAK TERSENTUH${NC}"
echo -e "============================================"

# Cek apakah user rendzz sudah ada
if id "$USERNAME" &>/dev/null; then
    echo -e "${GREEN}[✓] User $USERNAME sudah ada${NC}"
else
    echo -e "${YELLOW}[!] Membuat user $USERNAME...${NC}"
    useradd -m -s /bin/bash $USERNAME
    echo -e "${YELLOW}Masukkan password untuk user $USERNAME:${NC}"
    passwd $USERNAME
    usermod -aG sudo $USERNAME 2>/dev/null
    echo -e "${GREEN}[✓] User $USERNAME dibuat${NC}"
fi

# Backup config SSH
cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak.$(date +%Y%m%d)
echo -e "${YELLOW}[1/5] Backup config SSH OK${NC}"

# Hapus semua baris Port yang ada
sed -i '/^Port /d' /etc/ssh/sshd_config

# Tambah port baru
echo "Port $NEW_SSH_PORT" >> /etc/ssh/sshd_config
echo -e "${YELLOW}[2/5] Port SSH diubah -> $NEW_SSH_PORT${NC}"

# Hardening SSH (tanpa ganggu config lain)
sed -i 's/^#PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config
sed -i 's/^PermitRootLogin yes/PermitRootLogin no/' /etc/ssh/sshd_config

sed -i 's/^#PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
sed -i 's/^PasswordAuthentication yes/PasswordAuthentication no/' /etc/ssh/sshd_config

sed -i 's/^#PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config

# Tambah konfigurasi keamanan (kalau belum ada)
grep -q "^MaxAuthTries" /etc/ssh/sshd_config || echo "MaxAuthTries 3" >> /etc/ssh/sshd_config
grep -q "^ClientAliveInterval" /etc/ssh/sshd_config || echo "ClientAliveInterval 300" >> /etc/ssh/sshd_config
grep -q "^ClientAliveCountMax" /etc/ssh/sshd_config || echo "ClientAliveCountMax 2" >> /etc/ssh/sshd_config
grep -q "^AllowUsers" /etc/ssh/sshd_config || echo "AllowUsers $USERNAME" >> /etc/ssh/sshd_config

echo -e "${YELLOW}[3/5] SSH Hardening OK${NC}"

# Install fail2ban (kalau belum ada)
if ! command -v fail2ban-server &>/dev/null; then
    echo -e "${YELLOW}[4/5] Install fail2ban...${NC}"
    if command -v apt &>/dev/null; then
        apt update -y
        apt install fail2ban -y
    elif command -v yum &>/dev/null; then
        yum install epel-release -y
        yum install fail2ban -y
    fi
else
    echo -e "${GREEN}[✓] Fail2ban sudah terinstall${NC}"
fi

# Config fail2ban khusus SSH (TIDAK ganggu web)
cat > /etc/fail2ban/jail.local <<EOF
[DEFAULT]
bantime = 3600
findtime = 600
maxretry = 3
ignoreip = 127.0.0.1/8

[sshd]
enabled = true
port = $NEW_SSH_PORT
logpath = /var/log/auth.log
maxretry = 3
bantime = 3600
EOF

# Untuk CentOS/RHEL
if [[ -f /var/log/secure ]]; then
    sed -i 's|logpath = /var/log/auth.log|logpath = /var/log/secure|' /etc/fail2ban/jail.local
fi

systemctl enable fail2ban
systemctl restart fail2ban
echo -e "${YELLOW}[5/5] Fail2ban aktif (khusus SSH)${NC}"

# Setup firewall (TAMBAH aturan, bukan hapus)
echo -e "${YELLOW}[+] Konfigurasi firewall...${NC}"

if command -v ufw &>/dev/null; then
    # UFW - Tambah aturan tanpa reset
    ufw allow $NEW_SSH_PORT/tcp comment 'SSH Baru'
    ufw allow 22/tcp comment 'SSH Lama (sementara)'
    ufw allow 80/tcp comment 'HTTP - Pterodactyl'
    ufw allow 443/tcp comment 'HTTPS - Pterodactyl'
    ufw allow 2022/tcp comment 'Pterodactyl Wings'
    ufw allow 8080/tcp comment 'Pterodactyl Server'
    ufw allow 25565/tcp comment 'Minecraft'
    
    # Enable UFW kalau belum aktif
    ufw status | grep -q "inactive" && echo "y" | ufw enable
    
elif command -v firewall-cmd &>/dev/null; then
    # Firewalld
    systemctl start firewalld
    systemctl enable firewalld
    firewall-cmd --permanent --add-port=$NEW_SSH_PORT/tcp
    firewall-cmd --permanent --add-service=http
    firewall-cmd --permanent --add-service=https
    firewall-cmd --permanent --add-port=2022/tcp
    firewall-cmd --permanent --add-port=8080/tcp
    firewall-cmd --permanent --add-port=25565/tcp
    firewall-cmd --reload
fi

# Restart SSH
systemctl restart sshd 2>/dev/null || systemctl restart ssh

# Selesai
echo -e "${GREEN}============================================${NC}"
echo -e "${GREEN}✓ VPS AMAN - PTERODACTYL TETAP NORMAL!${NC}"
echo -e "${GREEN}============================================${NC}"
echo -e "Port SSH baru   : ${YELLOW}$NEW_SSH_PORT${NC}"
echo -e "Username login  : ${YELLOW}$USERNAME${NC}"
echo -e "Root login      : ${RED}DISABLED${NC}"
echo -e "Password login  : ${RED}DISABLED${NC} (harus pake SSH key)"
echo -e "Fail2ban        : ${GREEN}AKTIF${NC}"
echo -e ""
echo -e "${YELLOW}⚠️  PENTING UNTUK PTERODACTYL:${NC}"
echo -e "${GREEN}✓ Panel web (80/443) tetap jalan${NC}"
echo -e "${GREEN}✓ Wings (2022) tetap jalan${NC}"
echo -e "${GREEN}✓ Port game (25565,8080) tetap jalan${NC}"
echo -e ""
echo -e "${YELLOW}📝 CARA LOGIN BARU:${NC}"
echo -e "1. Dari komputer lokal, copy SSH key dulu:"
echo -e "   ${GREEN}ssh-copy-id -p $NEW_SSH_PORT $USERNAME@ip-vps-kamu${NC}"
echo -e ""
echo -e "2. Login pake port baru:"
echo -e "   ${GREEN}ssh -p $NEW_SSH_PORT $USERNAME@ip-vps-kamu${NC}"
echo -e ""
echo -e "${RED}⚠️  JANGAN LOGOUT SEBELUM TEST LOGIN DENGAN PORT BARU!${NC}"
echo -e "${RED}   Buka terminal baru buat test dulu${NC}"
