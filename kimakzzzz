#!/bin/bash

# Restore VPS ke default (SSH + Firewall)

NC='\033[0m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'

echo -e "${GREEN}====================================${NC}"
echo -e "${GREEN}   RESTORE VPS KE KONDISI DEFAULT${NC}"
echo -e "${GREEN}====================================${NC}"

# Pastikan dijalankan sebagai root
if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}Harus root! Jalankan sebagai root.${NC}"
   exit 1
fi

# Backup konfigurasi SSH
echo -e "${YELLOW}Membuat backup sshd_config...${NC}"
cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak.$(date +%Y%m%d)

# Restore konfigurasi default SSH
echo -e "${YELLOW}Mengembalikan konfigurasi default SSH...${NC}"
cat > /etc/ssh/sshd_config <<EOF
Port 22
PermitRootLogin yes
PasswordAuthentication yes
PubkeyAuthentication yes
ChallengeResponseAuthentication no
UsePAM yes
X11Forwarding yes
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server
EOF

# Restart SSH service
echo -e "${YELLOW}Restart SSH service...${NC}"
systemctl restart sshd || systemctl restart ssh

# Reset firewall (UFW) ke kondisi default
if command -v ufw &>/dev/null; then
    echo -e "${YELLOW}Mereset firewall UFW ke default...${NC}"
    ufw --force disable
    ufw --force reset
    ufw allow 22/tcp
    ufw allow 80/tcp
    ufw allow 443/tcp
    ufw --force enable
    echo -e "${GREEN}UFW firewall di-reset ke default${NC}"
else
    echo -e "${RED}UFW tidak ditemukan. Jika pakai firewalld, perlu diatur manual.${NC}"
fi

# Pastikan fail2ban restart (opsional)
if command -v fail2ban-server &>/dev/null; then
    echo -e "${YELLOW}Restart fail2ban...${NC}"
    systemctl restart fail2ban
fi

echo -e "${GREEN}====================================${NC}"
echo -e "${GREEN}✓ VPS KEMBALI KE KONDISI DEFAULT${NC}"
echo -e "${GREEN}====================================${NC}"
echo -e "Port SSH: 22"
echo -e "Root login: ${GREEN}DISESUAIKAN ULANG${NC} (aktif)"
echo -e "Password login: ${GREEN}AKTIF${NC}"
echo -e "Firewall: ${GREEN}UFW RESET, port 22/80/443 terbuka${NC}"
echo ""
echo -e "${YELLOW}PENTING: Coba login ulang sekarang.${NC}"
echo -e "ssh root@IP-VPS-LO (gunakan password yang sesuai)"
echo -e "${GREEN}Jangan lupa ganti password root jika diperlukan!${NC}"
