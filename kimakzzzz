#!/bin/bash

echo "RESTORE VPS KE DEFAULT..."

# Restore SSH config default
cat > /etc/ssh/sshd_config <<EOF
Port 22
PermitRootLogin yes
PasswordAuthentication yes
PubkeyAuthentication yes
ChallengeResponseAuthentication no
UsePAM yes
X11Forwarding yes
PrintMotd no
AcceptEnv LANG LC_*
Subsystem sftp /usr/lib/openssh/sftp-server
EOF

echo "SSH config restored"

# Restart SSH
systemctl restart sshd 2>/dev/null || systemctl restart ssh

# Reset firewall
if command -v ufw &>/dev/null; then
ufw --force disable
ufw --force reset
ufw allow 22/tcp
ufw allow 80/tcp
ufw allow 443/tcp
ufw allow 8080/tcp
ufw allow 2022/tcp
ufw --force enable
echo "UFW restored"
fi

# Restart services penting
systemctl restart nginx 2>/dev/null
systemctl restart wings 2>/dev/null
systemctl restart mysql 2>/dev/null
systemctl restart redis-server 2>/dev/null

echo "=================================="
echo "VPS SUDAH KEMBALI DEFAULT"
echo "=================================="
echo "Login normal:"
echo "ssh root@IP-VPS"
echo ""
echo "Port: 22"
echo "Root login: ENABLED"
echo "Password login: ENABLED"
