#!/bin/bash

NC='\033[0m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'

if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}Harus root!${NC}"
   exit 1
fi

NEW_SSH_PORT="${1:-2222}"

echo -e "${GREEN}=================================="
echo -e " AUTO SECURE VPS INSTALLER AUTO USER"
echo -e "==================================${NC}"

# Generate random username & password
NEW_USER="user$(shuf -i 1000-9999 -n 1)"
NEW_PASS="$(openssl rand -base64 12)"

echo -e "${YELLOW}Membuat user otomatis...${NC}"

adduser --disabled-password --gecos "" $NEW_USER
echo "$NEW_USER:$NEW_PASS" | chpasswd
usermod -aG sudo $NEW_USER

mkdir -p /home/$NEW_USER/.ssh
chmod 700 /home/$NEW_USER/.ssh
chown -R $NEW_USER:$NEW_USER /home/$NEW_USER/.ssh

echo -e "${GREEN}User dibuat: $NEW_USER${NC}"

# Backup SSH config
cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak

# Ganti port
sed -i "s/^#Port 22/Port $NEW_SSH_PORT/" /etc/ssh/sshd_config
sed -i "s/^Port 22/Port $NEW_SSH_PORT/" /etc/ssh/sshd_config

# Hardening
cat >> /etc/ssh/sshd_config <<EOF

PermitRootLogin no
PasswordAuthentication yes
PubkeyAuthentication yes
MaxAuthTries 3
ClientAliveInterval 300
ClientAliveCountMax 2
EOF

# Install security tools
apt update -y
apt install fail2ban ufw -y

cat > /etc/fail2ban/jail.local <<EOF
[sshd]
enabled = true
port = $NEW_SSH_PORT
maxretry = 3
bantime = 3600
EOF

systemctl enable fail2ban
systemctl restart fail2ban

ufw --force reset
ufw default deny incoming
ufw default allow outgoing
ufw allow $NEW_SSH_PORT/tcp
ufw allow 80/tcp
ufw allow 443/tcp
ufw --force enable

systemctl restart sshd 2>/dev/null || systemctl restart ssh

echo -e "${GREEN}=================================="
echo -e "✓ VPS AMAN & USER AUTO DIBUAT"
echo -e "==================================${NC}"

echo -e "${YELLOW}Username:${NC} $NEW_USER"
echo -e "${YELLOW}Password:${NC} $NEW_PASS"
echo -e "${YELLOW}Port SSH:${NC} $NEW_SSH_PORT"

echo ""
echo -e "${GREEN}Login command:${NC}"
echo -e "ssh -p $NEW_SSH_PORT $NEW_USER@IP-VPS-LO"
